    92	def standard_attention(q, k, v):
    93	    """Full causal self-attention through PyTorch SDPA."""
    94	    q = q.transpose(1, 2)
    95	    k = k.transpose(1, 2)
    96	    v = v.transpose(1, 2)
    97	    y = F.scaled_dot_product_attention(q, k, v, is_causal=True)
    98	    return y.transpose(1, 2)
