   517	# Schedules (all based on progress = training_time / TIME_BUDGET_SECONDS)
   518	
   519	def get_lr_multiplier(progress):
   520	    if progress < CONFIG.warmup_ratio:
   521	        return progress / CONFIG.warmup_ratio if CONFIG.warmup_ratio > 0 else 1.0
   522	    elif progress < 1.0 - CONFIG.warmdown_ratio:
   523	        return 1.0
   524	    else:
   525	        cooldown = (1.0 - progress) / CONFIG.warmdown_ratio
   526	        return cooldown * 1.0 + (1 - cooldown) * CONFIG.final_lr_frac
   527	
   528	def get_muon_momentum(step):
   529	    frac = min(step / CONFIG.muon_momentum_warmup_steps, 1)
   530	    return (1 - frac) * CONFIG.muon_momentum_start + frac * CONFIG.muon_momentum_end
   531	
   532	def get_weight_decay(progress):
   533	    return CONFIG.weight_decay * (1 - progress) if CONFIG.weight_decay_decay else CONFIG.weight_decay
   534	
   535	# ---------------------------------------------------------------------------
   536	# Training loop
   537	# ---------------------------------------------------------------------------
   538	
   539	t_start_training = time.time()
   540	smooth_train_loss = 0
   541	total_training_time = 0
   542	step = 0
   543	
   544	while True:
   545	    if device.type == "cuda":
   546	        torch.cuda.synchronize()
   547	    t0 = time.time()
   548	    for micro_step in range(grad_accum_steps):
   549	        with autocast_ctx:
   550	            loss = model(x, y)
   551	        train_loss = loss.detach()
   552	        loss = loss / grad_accum_steps
   553	        loss.backward()
   554	        x, y, epoch = next(train_loader)
   555	
   556	    # Progress and schedules
   557	    progress = min(total_training_time / TIME_BUDGET_SECONDS, 1.0)
   558	    lrm = get_lr_multiplier(progress)
   559	    muon_momentum = get_muon_momentum(step)
   560	    muon_weight_decay = get_weight_decay(progress)
   561	    for group in optimizer.param_groups:
   562	        group["lr"] = group["initial_lr"] * lrm
   563	        if group['kind'] == 'muon':
   564	            group["momentum"] = muon_momentum
   565	            group["weight_decay"] = muon_weight_decay
   566	    optimizer.step()
   567	    model.zero_grad(set_to_none=True)
   568	
   569	    train_loss_f = train_loss.item()
   570	
   571	    # Fast fail: abort if loss is exploding or NaN
   572	    if math.isnan(train_loss_f) or train_loss_f > LOSS_FAIL_THRESHOLD:
   573	        print("FAIL")
   574	        exit(1)
   575	
   576	    if device.type == "cuda":
   577	        torch.cuda.synchronize()
   578	    t1 = time.time()
   579	    dt = t1 - t0
   580	
   581	    if step > WARMUP_STEPS_EXCLUDED_FROM_TIMING:
   582	        total_training_time += dt
   583	
   584	    # Logging
   585	    ema_beta = EMA_BETA
   586	    smooth_train_loss = ema_beta * smooth_train_loss + (1 - ema_beta) * train_loss_f
   587	    debiased_smooth_loss = smooth_train_loss / (1 - ema_beta**(step + 1))
   588	    pct_done = 100 * progress
   589	    tok_per_sec = int(CONFIG.total_batch_size / dt)
   590	    mfu = 100 * num_flops_per_token * CONFIG.total_batch_size / dt / CONFIG.h100_bf16_peak_flops
   591	    remaining = max(0, TIME_BUDGET_SECONDS - total_training_time)
   592	
   593	    print(f"\rstep {step:05d} ({pct_done:.1f}%) | loss: {debiased_smooth_loss:.6f} | lrm: {lrm:.2f} | dt: {dt*1000:.0f}ms | tok/sec: {tok_per_sec:,} | mfu: {mfu:.1f}% | epoch: {epoch} | remaining: {remaining:.0f}s    ", end="", flush=True)
   594	
   595	    # GC management (Python's GC causes ~500ms stalls)
   596	    if step == 0 and GC_FREEZE_AFTER_FIRST_STEP:
   597	        gc.collect()
   598	        gc.freeze()
   599	        gc.disable()
   600	    elif GC_COLLECT_INTERVAL > 0 and (step + 1) % GC_COLLECT_INTERVAL == 0:
   601	        gc.collect()
   602	
   603	    step += 1
   604	
   605	    # Time's up — but only stop after warmup steps so we don't count compilation
   606	    if step > WARMUP_STEPS_EXCLUDED_FROM_TIMING and total_training_time >= TIME_BUDGET_SECONDS:
   607	        break
   608	
   609	print()  # newline after \r training log
   610	
   611	total_tokens = step * CONFIG.total_batch_size
   612	
   613	# Final eval
   614	model.eval()
   615	with autocast_ctx:
   616	    metric_value = evaluate_model(
   617	        model,
   618	        tokenizer,
   619	        CONFIG.device_batch_size,
   620	        sequence_len=CONFIG.sequence_len,
   621	        buffer_size=CONFIG.dataloader_buffer_size,
   622	        tokenizer_batch_size=CONFIG.tokenizer_batch_size,
   623	        device=device.type,
   624	    )
   625	
   626	# Final summary
   627	t_end = time.time()
   628	startup_time = t_start_training - t_start
   629	timed_steps = step - WARMUP_STEPS_EXCLUDED_FROM_TIMING
   630	steady_state_mfu = 100 * num_flops_per_token * CONFIG.total_batch_size * timed_steps / total_training_time / CONFIG.h100_bf16_peak_flops if total_training_time > 0 else 0
   631	peak_vram_mb = torch.cuda.max_memory_allocated() / 1024 / 1024 if device.type == "cuda" else 0.0
   632	metrics = {
   633	    "val_bpb": float(metric_value),
   634	    "training_seconds": float(total_training_time),
   635	    "total_seconds": float(t_end - t_start),
   636	    "peak_vram_mb": float(peak_vram_mb),
   637	    "mfu_percent": float(steady_state_mfu),
   638	    "total_tokens_M": float(total_tokens / 1e6),
   639	    "num_steps": int(step),
   640	    "num_params_M": float(num_params / 1e6),
   641	    "depth": int(CONFIG.depth),
   642	}
   643	metrics_tmp_path = METRICS_PATH.with_suffix(".json.tmp")
   644	with metrics_tmp_path.open("w", encoding="utf-8") as f:
   645	    json.dump(metrics, f, indent=2, sort_keys=True)
   646	    f.write("\n")
   647	metrics_tmp_path.replace(METRICS_PATH)
   648	
   649	print("---")
   650	print(f"{'val_bpb:':18s}{metric_value:.6f}")
   651	print(f"training_seconds: {total_training_time:.1f}")
   652	print(f"total_seconds:    {t_end - t_start:.1f}")
   653	print(f"peak_vram_mb:     {peak_vram_mb:.1f}")
   654	print(f"mfu_percent:      {steady_state_mfu:.2f}")
   655	print(f"total_tokens_M:   {total_tokens / 1e6:.1f}")
   656	print(f"num_steps:        {step}")
   657	print(f"num_params_M:     {num_params / 1e6:.1f}")
   658	print(f"depth:            {CONFIG.depth}")

