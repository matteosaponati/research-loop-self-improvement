   101	class CausalSelfAttention(nn.Module):
   102	    def __init__(self, config):
   103	        super().__init__()
   104	        self.n_head = config.n_head
   105	        self.n_embd = config.n_embd
   106	        self.head_dim = self.n_embd // self.n_head
   107	        assert self.n_embd % self.n_head == 0
   108	        self.c_q = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   109	        self.c_k = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   110	        self.c_v = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   111	        self.c_proj = nn.Linear(self.n_embd, self.n_embd, bias=False)
   112	
   113	    def forward(self, x, cos_sin):
   114	        B, T, C = x.size()
   115	        q = self.c_q(x).view(B, T, self.n_head, self.head_dim)
   116	        k = self.c_k(x).view(B, T, self.n_head, self.head_dim)
   117	        v = self.c_v(x).view(B, T, self.n_head, self.head_dim)
   118	
   119	        cos, sin = cos_sin
   120	        q, k = apply_rotary_emb(q, cos, sin), apply_rotary_emb(k, cos, sin)
   121	        q, k = norm(q), norm(k)
   122	
   123	        y = standard_attention(q, k, v)
   124	        y = y.contiguous().view(B, T, -1)
   125	        y = self.c_proj(y)
   126	        return y
   127	
   128	
   129	class MLP(nn.Module):
   130	    def __init__(self, config):
   131	        super().__init__()
   132	        hidden_dim = config.mlp_hidden_multiplier * config.n_embd
   133	        self.c_fc = nn.Linear(config.n_embd, hidden_dim, bias=False)
   134	        self.c_proj = nn.Linear(hidden_dim, config.n_embd, bias=False)
   135	
   136	    def forward(self, x):
   137	        x = self.c_fc(x)
   138	        x = F.relu(x).square()
   139	        x = self.c_proj(x)
   140	        return x
   141	
   142	
   143	class Block(nn.Module):
   144	    def __init__(self, config):
   145	        super().__init__()
   146	        self.attn = CausalSelfAttention(config)
   147	        self.mlp = MLP(config)
   148	
   149	    def forward(self, x, cos_sin):
   150	        x = x + self.attn(norm(x), cos_sin)
   151	        x = x + self.mlp(norm(x))
   152	        return x
   153	
   154	
   155	class GPT(nn.Module):
   156	    def __init__(self, config):
   157	        super().__init__()
   158	        self.config = config
   159	        self.transformer = nn.ModuleDict({
   160	            "wte": nn.Embedding(config.vocab_size, config.n_embd),
   161	            "h": nn.ModuleList([Block(config) for _ in range(config.n_layer)]),
   162	        })
   163	        self.lm_head = nn.Linear(config.n_embd, config.vocab_size, bias=False)
   164	        head_dim = config.n_embd // config.n_head
   165	        # Rotary embeddings
   166	        self.rotary_seq_len = config.sequence_len * config.rotary_seq_len_multiplier
   167	        cos, sin = self._precompute_rotary_embeddings(self.rotary_seq_len, head_dim)
   168	        self.register_buffer("cos", cos, persistent=False)
   169	        self.register_buffer("sin", sin, persistent=False)
   170	
   171	    @torch.no_grad()
   172	    def init_weights(self):
   173	        # Embedding and unembedding
   174	        torch.nn.init.normal_(self.transformer.wte.weight, mean=self.config.init_wte_mean, std=self.config.init_wte_std)
   175	        torch.nn.init.normal_(self.lm_head.weight, mean=self.config.init_lm_head_mean, std=self.config.init_lm_head_std)
   176	        # Transformer blocks
   177	        n_embd = self.config.n_embd
   178	        s = self.config.init_matrix_scale * n_embd**-0.5
   179	        for block in self.transformer.h:
   180	            torch.nn.init.uniform_(block.attn.c_q.weight, -s, s)
   181	            torch.nn.init.uniform_(block.attn.c_k.weight, -s, s)
   182	            torch.nn.init.uniform_(block.attn.c_v.weight, -s, s)
   183	            torch.nn.init.zeros_(block.attn.c_proj.weight)
   184	            torch.nn.init.uniform_(block.mlp.c_fc.weight, -s, s)
   185	            torch.nn.init.zeros_(block.mlp.c_proj.weight)
   186	        # Rotary embeddings
   187	        head_dim = self.config.n_embd // self.config.n_head
   188	        cos, sin = self._precompute_rotary_embeddings(self.rotary_seq_len, head_dim)
   189	        self.cos, self.sin = cos, sin
   190	        # Keep CPU dtype consistent; bf16 embedding is only used on CUDA.
   191	        if self.transformer.wte.weight.device.type == "cuda":
   192	            self.transformer.wte.to(dtype=torch.bfloat16)
   193	
   194	    def _precompute_rotary_embeddings(self, seq_len, head_dim, base=None, device=None):
   195	        if base is None:
   196	            base = self.config.rotary_base
   197	        if device is None:
   198	            device = self.transformer.wte.weight.device
   199	        channel_range = torch.arange(0, head_dim, 2, dtype=torch.float32, device=device)
   200	        inv_freq = 1.0 / (base ** (channel_range / head_dim))
   201	        t = torch.arange(seq_len, dtype=torch.float32, device=device)
   202	        freqs = torch.outer(t, inv_freq)
   203	        cos, sin = freqs.cos(), freqs.sin()
   204	        cos, sin = cos.bfloat16(), sin.bfloat16()
   205	        cos, sin = cos[None, :, None, :], sin[None, :, None, :]
   206	        return cos, sin
   207	
   208	    def estimate_flops(self):
   209	        """Estimated FLOPs per token (forward + backward)."""
   210	        nparams = sum(p.numel() for p in self.parameters())
   211	        nparams_exclude = self.transformer.wte.weight.numel()
   212	        h = self.config.n_head
   213	        q = self.config.n_embd // self.config.n_head
   214	        t = self.config.sequence_len
   215	        attn_flops = self.config.n_layer * 12 * h * q * t
   216	        return 6 * (nparams - nparams_exclude) + attn_flops
   217	
   218	    def num_scaling_params(self):
   219	        wte = sum(p.numel() for p in self.transformer.wte.parameters())
   220	        lm_head = sum(p.numel() for p in self.lm_head.parameters())
   221	        transformer_matrices = sum(p.numel() for p in self.transformer.h.parameters())
   222	        total = wte + lm_head + transformer_matrices
   223	        return {
   224	            'wte': wte, 'lm_head': lm_head,
   225	            'transformer_matrices': transformer_matrices, 'total': total,
   226	        }
   227	
   228	    def setup_optimizer(self, unembedding_lr, embedding_lr, matrix_lr, weight_decay,
   229	                        adam_betas, adam_eps, dmodel_lr_reference,
   230	                        muon_initial_momentum, muon_ns_steps, muon_beta2):
   231	        model_dim = self.config.n_embd
   232	        matrix_params = list(self.transformer.h.parameters())
   233	        embedding_params = list(self.transformer.wte.parameters())
   234	        lm_head_params = list(self.lm_head.parameters())
   235	        assert len(list(self.parameters())) == (len(matrix_params) + len(embedding_params) +
   236	            len(lm_head_params))
   237	        # Scale LR ∝ 1/√dmodel (tuned at 768 dim)
   238	        dmodel_lr_scale = (model_dim / dmodel_lr_reference) ** -0.5
   239	        print(f"Scaling AdamW LRs by 1/sqrt({model_dim}/{dmodel_lr_reference}) = {dmodel_lr_scale:.6f}")
   240	        param_groups = [
   241	            dict(kind='adamw', params=lm_head_params, lr=unembedding_lr * dmodel_lr_scale, betas=adam_betas, eps=adam_eps, weight_decay=0.0),
   242	            dict(kind='adamw', params=embedding_params, lr=embedding_lr * dmodel_lr_scale, betas=adam_betas, eps=adam_eps, weight_decay=0.0),
   243	        ]
   244	        for shape in sorted({p.shape for p in matrix_params}):
   245	            group_params = [p for p in matrix_params if p.shape == shape]
   246	            param_groups.append(dict(
   247	                kind='muon', params=group_params, lr=matrix_lr,
   248	                momentum=muon_initial_momentum, ns_steps=muon_ns_steps, beta2=muon_beta2, weight_decay=weight_decay,
   249	            ))
   250	        optimizer = MuonAdamW(param_groups)
   251	        for group in optimizer.param_groups:
   252	            group["initial_lr"] = group["lr"]
   253	        return optimizer
   254	
   255	    def forward(self, idx, targets=None, reduction='mean'):
   256	        B, T = idx.size()
   257	        assert T <= self.cos.size(1)
   258	        cos_sin = self.cos[:, :T], self.sin[:, :T]
   259	
   260	        x = self.transformer.wte(idx)
   261	        x = norm(x)
   262	        for block in self.transformer.h:
   263	            x = block(x, cos_sin)
   264	        x = norm(x)
   265	
   266	        softcap = self.config.softcap
   267	        logits = self.lm_head(x)
   268	        logits = logits.float()
   269	        logits = softcap * torch.tanh(logits / softcap)
   270	
   271	        if targets is not None:
   272	            loss = F.cross_entropy(logits.view(-1, logits.size(-1)), targets.view(-1),
   273	                                   ignore_index=self.config.ignore_index, reduction=reduction)
   274	            return loss
   275	        return logits
   276	
   277	# ---------------------------------------------------------------------------
   278	# Optimizer (MuonAdamW, single GPU only)
   279	# ---------------------------------------------------------------------------
   280	
   281	polar_express_coeffs = [
   282	    (8.156554524902461, -22.48329292557795, 15.878769915207462),
   283	    (4.042929935166739, -2.808917465908714, 0.5000178451051316),
   284	    (3.8916678022926607, -2.772484153217685, 0.5060648178503393),
   285	    (3.285753657755655, -2.3681294933425376, 0.46449024233003106),
   286	    (2.3465413258596377, -1.7097828382687081, 0.42323551169305323),
   287	]
   288	
   289	def adamw_step_fused(p, grad, exp_avg, exp_avg_sq, step_t, lr_t, beta1_t, beta2_t, eps_t, wd_t):
   290	    p.mul_(1 - lr_t * wd_t)
   291	    exp_avg.lerp_(grad, 1 - beta1_t)
   292	    exp_avg_sq.lerp_(grad.square(), 1 - beta2_t)
   293	    bias1 = 1 - beta1_t ** step_t
   294	    bias2 = 1 - beta2_t ** step_t
   295	    denom = (exp_avg_sq / bias2).sqrt() + eps_t
   296	    step_size = lr_t / bias1
   297	    p.add_(exp_avg / denom, alpha=-step_size)
   298	
   299	def muon_step_fused(stacked_grads, stacked_params, momentum_buffer, second_momentum_buffer,
   300	                    momentum_t, lr_t, wd_t, beta2_t, ns_steps, red_dim):
   301	    # Nesterov momentum
   302	    momentum = momentum_t.to(stacked_grads.dtype)
   303	    momentum_buffer.lerp_(stacked_grads, 1 - momentum)
   304	    g = stacked_grads.lerp_(momentum_buffer, momentum)
   305	    # Polar express orthogonalization
   306	    X = g.bfloat16()
   307	    X = X / (X.norm(dim=(-2, -1), keepdim=True) * 1.02 + 1e-6)
   308	    if g.size(-2) > g.size(-1):
   309	        for a, b, c in polar_express_coeffs[:ns_steps]:
   310	            A = X.mT @ X
   311	            B = b * A + c * (A @ A)
   312	            X = a * X + X @ B
   313	    else:
   314	        for a, b, c in polar_express_coeffs[:ns_steps]:
   315	            A = X @ X.mT
   316	            B = b * A + c * (A @ A)
   317	            X = a * X + B @ X
   318	    g = X
   319	    # NorMuon variance reduction
   320	    beta2 = beta2_t.to(g.dtype)
   321	    v_mean = g.float().square().mean(dim=red_dim, keepdim=True)
   322	    red_dim_size = g.size(red_dim)
   323	    v_norm_sq = v_mean.sum(dim=(-2, -1), keepdim=True) * red_dim_size
   324	    v_norm = v_norm_sq.sqrt()
   325	    second_momentum_buffer.lerp_(v_mean.to(dtype=second_momentum_buffer.dtype), 1 - beta2)
   326	    step_size = second_momentum_buffer.clamp_min(1e-10).rsqrt()
   327	    scaled_sq_sum = (v_mean * red_dim_size) * step_size.float().square()
   328	    v_norm_new = scaled_sq_sum.sum(dim=(-2, -1), keepdim=True).sqrt()
   329	    final_scale = step_size * (v_norm / v_norm_new.clamp_min(1e-10))
   330	    g = g * final_scale.to(g.dtype)
   331	    # Cautious weight decay + parameter update
   332	    lr = lr_t.to(g.dtype)
   333	    wd = wd_t.to(g.dtype)
   334	    mask = (g * stacked_params) >= 0
   335	    stacked_params.sub_(lr * g + lr * wd * stacked_params * mask)
   336	
   337	
   338	class MuonAdamW(torch.optim.Optimizer):
   339	    """Combined optimizer: Muon for 2D matrix params, AdamW for others."""
   340	
   341	    def __init__(self, param_groups):
   342	        super().__init__(param_groups, defaults={})
   343	        # 0-D CPU tensors to avoid torch.compile recompilation when values change
   344	        self._adamw_step_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   345	        self._adamw_lr_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   346	        self._adamw_beta1_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   347	        self._adamw_beta2_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   348	        self._adamw_eps_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   349	        self._adamw_wd_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   350	        self._muon_momentum_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   351	        self._muon_lr_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   352	        self._muon_wd_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   353	        self._muon_beta2_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   354	
   355	    def _step_adamw(self, group):
   356	        for p in group['params']:
   357	            if p.grad is None:
   358	                continue
   359	            grad = p.grad
   360	            state = self.state[p]
   361	            if not state:
   362	                state['step'] = 0
   363	                state['exp_avg'] = torch.zeros_like(p)
   364	                state['exp_avg_sq'] = torch.zeros_like(p)
   365	            state['step'] += 1
   366	            self._adamw_step_t.fill_(state['step'])
   367	            self._adamw_lr_t.fill_(group['lr'])
   368	            self._adamw_beta1_t.fill_(group['betas'][0])
   369	            self._adamw_beta2_t.fill_(group['betas'][1])
   370	            self._adamw_eps_t.fill_(group['eps'])
   371	            self._adamw_wd_t.fill_(group['weight_decay'])
   372	            adamw_step_fused(p, grad, state['exp_avg'], state['exp_avg_sq'],
   373	                            self._adamw_step_t, self._adamw_lr_t, self._adamw_beta1_t,
   374	                            self._adamw_beta2_t, self._adamw_eps_t, self._adamw_wd_t)
   375	
   376	    def _step_muon(self, group):
   377	        params = group['params']
   378	        if not params:
   379	            return
   380	        p = params[0]
   381	        state = self.state[p]
   382	        num_params = len(params)
   383	        shape, device, dtype = p.shape, p.device, p.dtype
   384	        if "momentum_buffer" not in state:
   385	            state["momentum_buffer"] = torch.zeros(num_params, *shape, dtype=dtype, device=device)
   386	        if "second_momentum_buffer" not in state:
   387	            state_shape = (num_params, shape[-2], 1) if shape[-2] >= shape[-1] else (num_params, 1, shape[-1])
   388	            state["second_momentum_buffer"] = torch.zeros(state_shape, dtype=dtype, device=device)
   389	        red_dim = -1 if shape[-2] >= shape[-1] else -2
   390	        stacked_grads = torch.stack([p.grad for p in params])
   391	        stacked_params = torch.stack(params)
   392	        self._muon_momentum_t.fill_(group["momentum"])
   393	        self._muon_beta2_t.fill_(group["beta2"] if group["beta2"] is not None else 0.0)
   394	        self._muon_lr_t.fill_(group["lr"] * max(1.0, shape[-2] / shape[-1])**0.5)
   395	        self._muon_wd_t.fill_(group["weight_decay"])
   396	        muon_step_fused(stacked_grads, stacked_params,
   397	                        state["momentum_buffer"], state["second_momentum_buffer"],
   398	                        self._muon_momentum_t, self._muon_lr_t, self._muon_wd_t,
   399	                        self._muon_beta2_t, group["ns_steps"], red_dim)
   400	        torch._foreach_copy_(params, list(stacked_params.unbind(0)))
   401	
   402	    @torch.no_grad()
   403	    def step(self):
   404	        for group in self.param_groups:
   405	            if group['kind'] == 'adamw':
   406	                self._step_adamw(group)
   407	            elif group['kind'] == 'muon':
   408	                self._step_muon(group)
   409	
