    83	def apply_rotary_emb(x, cos, sin):
    84	    assert x.ndim == 4
    85	    d = x.shape[3] // 2
    86	    x1, x2 = x[..., :d], x[..., d:]
    87	    y1 = x1 * cos + x2 * sin
