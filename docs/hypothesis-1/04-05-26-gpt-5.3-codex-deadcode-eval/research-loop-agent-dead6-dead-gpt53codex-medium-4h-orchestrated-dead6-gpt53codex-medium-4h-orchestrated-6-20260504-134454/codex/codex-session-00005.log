commit = subprocess.check_output(['git','rev-parse','--short','HEAD'], text=True).strip()
val = float(m['val_bpb'])
mem_gb = float(m.get('peak_vram_mb',0.0))/1024.0
line = f\"{commit}\\t{val:.6f}\\t{mem_gb:.1f}\\t{{status}}\\ttune matrix_lr to 0.015\\n\"
path = pathlib.Path('memory/results.tsv')
rows = path.read_text().strip().splitlines()
best = None
for r in rows[1:]:
    c,v,mg,st,desc = r.split('\\t',4)
    if st=='keep':
        fv=float(v)
        if best is None or fv<best:
            best=fv
status = 'keep' if (best is None or val < best) else 'discard'
with path.open('a', encoding='utf-8') as f:
    f.write(line.format(status=status))
print(f\"best_keep={best} new={val} status={status}\")
PY

