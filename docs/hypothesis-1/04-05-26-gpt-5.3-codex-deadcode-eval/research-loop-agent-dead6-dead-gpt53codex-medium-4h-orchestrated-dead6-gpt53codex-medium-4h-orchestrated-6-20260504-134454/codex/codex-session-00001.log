    91	def standard_attention(q, k, v):
    92	    """Full causal self-attention through PyTorch SDPA."""
    93	    q = q.transpose(1, 2)
    94	    k = k.transpose(1, 2)
    95	    v = v.transpose(1, 2)
    96	    y = F.scaled_dot_product_attention(q, k, v, is_causal=True)
    97	    return y.transpose(1, 2)
