   128	class MLP(nn.Module):
   129	    def __init__(self, config):
   130	        super().__init__()
   131	        hidden_dim = config.mlp_hidden_multiplier * config.n_embd
   132	        self.c_fc = nn.Linear(config.n_embd, hidden_dim, bias=False)
   133	        self.c_proj = nn.Linear(hidden_dim, config.n_embd, bias=False)
   134	
   135	    def forward(self, x):
   136	        x = self.c_fc(x)
   137	        x = F.relu(x).square()
   138	        x = self.c_proj(x)
   139	        return x
