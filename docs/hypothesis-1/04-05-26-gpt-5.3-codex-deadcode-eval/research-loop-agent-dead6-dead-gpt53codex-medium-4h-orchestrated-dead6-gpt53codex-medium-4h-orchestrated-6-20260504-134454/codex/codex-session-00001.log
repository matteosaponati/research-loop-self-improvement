   142	class Block(nn.Module):
   143	    def __init__(self, config):
   144	        super().__init__()
   145	        self.attn = CausalSelfAttention(config)
   146	        self.mlp = MLP(config)
   147	
   148	    def forward(self, x, cos_sin):
   149	        x = x + self.attn(norm(x), cos_sin)
   150	        x = x + self.mlp(norm(x))
   151	        return x
