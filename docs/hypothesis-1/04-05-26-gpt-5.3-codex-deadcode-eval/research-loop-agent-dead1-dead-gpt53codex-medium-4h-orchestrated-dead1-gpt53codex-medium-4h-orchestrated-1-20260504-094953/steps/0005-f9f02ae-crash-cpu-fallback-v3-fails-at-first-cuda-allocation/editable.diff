 1 file changed, 35 insertions(+), 9 deletions(-)

diff --git a/editable/train.py b/editable/train.py
index 5252064..0f179a9 100644
--- a/editable/train.py
+++ b/editable/train.py
@@ -7,6 +7,7 @@ Usage: PYTHONPATH=research-loop uv run --project research-loop --extra research
 import json
 import os
 import sys
+from contextlib import nullcontext
 from pathlib import Path
 
 METRICS_PATH = Path("metrics.json")
@@ -413,11 +414,34 @@ class MuonAdamW(torch.optim.Optimizer):
 
 t_start = time.time()
 torch.manual_seed(CONFIG.seed)
-torch.cuda.manual_seed(CONFIG.seed)
+if torch.cuda.is_available():
+    torch.cuda.manual_seed(CONFIG.seed)
 torch.set_float32_matmul_precision(CONFIG.matmul_precision)
-device = torch.device(CONFIG.device)
+cuda_requested = CONFIG.device == "cuda"
+use_cuda = cuda_requested and torch.cuda.is_available()
+effective_device = "cuda" if use_cuda else "cpu"
+if cuda_requested and not use_cuda:
+    print("CUDA requested but unavailable; falling back to CPU.")
+
+if not use_cuda:
+    # immutable.prepare.make_dataloader uses pin_memory=True unconditionally.
+    # Disable it in CPU fallback to avoid CUDA driver init in torch.empty(..., pin_memory=True).
+    _torch_empty = torch.empty
+
+    def _empty_no_pin(*args, **kwargs):
+        if kwargs.get("pin_memory"):
+            kwargs["pin_memory"] = False
+        return _torch_empty(*args, **kwargs)
+
+    torch.empty = _empty_no_pin
+
+device = torch.device(effective_device)
 autocast_dtype = getattr(torch, CONFIG.autocast_dtype)
-autocast_ctx = torch.amp.autocast(device_type=CONFIG.device, dtype=autocast_dtype)
+autocast_ctx = (
+    torch.amp.autocast(device_type=effective_device, dtype=autocast_dtype)
+    if use_cuda
+    else nullcontext()
+)
 
 tokenizer = prepare.Tokenizer.from_directory(os.path.expanduser(str(prepare.TOKENIZER_DIR)))
 vocab_size = tokenizer.get_vocab_size()
