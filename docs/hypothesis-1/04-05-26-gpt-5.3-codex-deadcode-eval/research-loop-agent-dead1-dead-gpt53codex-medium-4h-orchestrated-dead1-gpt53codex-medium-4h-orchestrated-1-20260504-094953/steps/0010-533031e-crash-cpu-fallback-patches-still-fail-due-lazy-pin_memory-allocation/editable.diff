+
+def make_dataloader_safe(*args, **kwargs):
+    """On CPU-only runs, guard against pinned-memory CUDA allocator failures."""
+    if kwargs.get("device") != "cpu":
+        return prepare.make_dataloader(*args, **kwargs)
+    old_empty = torch.empty
+
+    def empty_no_pin(*a, **k):
+        k.pop("pin_memory", None)
+        return old_empty(*a, **k)
+
+    torch.empty = empty_no_pin
+    try:
+        return prepare.make_dataloader(*args, **kwargs)
+    finally:
+        torch.empty = old_empty
+
