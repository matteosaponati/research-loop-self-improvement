+
+def detect_usable_cuda(requested_device: str) -> bool:
+    if requested_device != "cuda" or not torch.cuda.is_available():
+        return False
+    try:
+        x = torch.empty(1, device="cuda")
+        del x
+        torch.cuda.synchronize()
+        return True
+    except Exception:
+        return False
+
+use_cuda = detect_usable_cuda(CONFIG.device)
+effective_device = "cuda" if use_cuda else "cpu"
+if not use_cuda and CONFIG.device == "cuda":
+    print("CUDA requested but unavailable or unusable; falling back to CPU.")
+if use_cuda:
+    torch.cuda.manual_seed(CONFIG.seed)
+
+if not use_cuda:
+    # immutable.prepare.make_dataloader allocates with pin_memory=True.
+    # Disable pinned memory in CPU fallback to avoid CUDA driver interaction.
+    _torch_empty = torch.empty
+
+    def _empty_no_pin(*args, **kwargs):
+        if kwargs.get("pin_memory"):
+            kwargs["pin_memory"] = False
+        return _torch_empty(*args, **kwargs)
+
+    torch.empty = _empty_no_pin
+
+device = torch.device(effective_device)
 autocast_dtype = getattr(torch, CONFIG.autocast_dtype)
-autocast_ctx = torch.amp.autocast(device_type=CONFIG.device, dtype=autocast_dtype)
+autocast_ctx = (
+    torch.amp.autocast(device_type=effective_device, dtype=autocast_dtype)
+    if use_cuda
+    else nullcontext()
+)
 
