/bin/bash -lc "uv run python - <<'PY'
import json, subprocess
from pathlib import Path

commit = subprocess.check_output(['git','rev-parse','--short','HEAD'], text=True).strip()
metrics = json.loads(Path('metrics.json').read_text())
val = float(metrics['val_bpb'])
mem_gb = float(metrics['peak_vram_mb'])/1024.0

results_path = Path('memory/results.tsv')
lines = [l for l in results_path.read_text().splitlines() if l.strip()]
vals = []
for row in lines[1:]:
    parts = row.split('\\t')
    if len(parts) >= 2:
        try:
            vals.append(float(parts[1]))
        except ValueError:
            pass
best_prev = min(vals) if vals else float('inf')
status = 'keep' if val < best_prev else 'discard'
desc = 'halve total_batch_size to 262144'
with results_path.open('a', encoding='utf-8') as f:
    f.write(f\"{commit}\\t{val:.6f}\\t{mem_gb:.1f}\\t{status}\\t{desc}\\n\")
print(f\"commit={commit}\")
print(f\"val_bpb={val:.6f}\")
print(f\"mem_gb={mem_gb:.1f}\")
print(f\"best_prev={best_prev:.6f}\")
print(f\"status={status}\")
