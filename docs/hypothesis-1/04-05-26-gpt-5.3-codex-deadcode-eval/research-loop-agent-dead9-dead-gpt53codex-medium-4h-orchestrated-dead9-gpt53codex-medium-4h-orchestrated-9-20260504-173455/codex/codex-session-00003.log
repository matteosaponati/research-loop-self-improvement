optimizer = model.setup_optimizer(
    unembedding_lr=CONFIG.unembedding_lr,
    embedding_lr=CONFIG.embedding_lr,
    adam_betas=CONFIG.adam_betas,
    matrix_lr=CONFIG.matrix_lr,
