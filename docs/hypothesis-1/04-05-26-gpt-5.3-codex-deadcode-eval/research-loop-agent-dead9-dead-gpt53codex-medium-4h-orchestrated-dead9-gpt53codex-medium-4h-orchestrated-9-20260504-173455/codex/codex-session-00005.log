if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from editable.config_loader import CONFIG
from immutable.eval import evaluate_model

PROJECT_NAME = "research_loops_stresstest"
RUNS_DIR = "runs"
