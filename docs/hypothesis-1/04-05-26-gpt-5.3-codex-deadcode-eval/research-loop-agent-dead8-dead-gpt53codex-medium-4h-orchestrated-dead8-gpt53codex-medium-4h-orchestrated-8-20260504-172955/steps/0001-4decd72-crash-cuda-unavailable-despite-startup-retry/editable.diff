    train: retry CUDA model allocation on startup
---
 editable/train.py | 20 +++++++++++++++++++-
 1 file changed, 19 insertions(+), 1 deletion(-)

diff --git a/editable/train.py b/editable/train.py
index 5252064..999fb39 100644
--- a/editable/train.py
+++ b/editable/train.py
@@ -33,6 +33,8 @@ LOSS_FAIL_THRESHOLD = 100.0
 EMA_BETA = 0.9
 GC_FREEZE_AFTER_FIRST_STEP = True
 GC_COLLECT_INTERVAL = 5000
+CUDA_INIT_RETRIES = 6
+CUDA_INIT_RETRY_SLEEP_SECONDS = 10
 
 os.environ["PYTORCH_ALLOC_CONF"] = PYTORCH_ALLOC_CONF
 os.environ["HF_HUB_DISABLE_PROGRESS_BARS"] = CONFIG.hf_hub_disable_progress_bars
@@ -447,7 +449,23 @@ print(f"Model config: {asdict(config)}")
 
 with torch.device("meta"):
     model = GPT(config)
-model.to_empty(device=device)
+
+def move_model_to_device_with_retry(model, device):
+    for attempt in range(1, CUDA_INIT_RETRIES + 1):
+        try:
+            model.to_empty(device=device)
+            return
+        except (torch.AcceleratorError, RuntimeError) as exc:
+            if "busy or unavailable" not in str(exc).lower() or attempt == CUDA_INIT_RETRIES:
+                raise
+            print(
+                f"CUDA unavailable during model allocation "
+                f"(attempt {attempt}/{CUDA_INIT_RETRIES}); retrying in "
+                f"{CUDA_INIT_RETRY_SLEEP_SECONDS}s..."
+            )
+            time.sleep(CUDA_INIT_RETRY_SLEEP_SECONDS)
+
+move_model_to_device_with_retry(model, device)
 model.init_weights()
 
 param_counts = model.num_scaling_params()
