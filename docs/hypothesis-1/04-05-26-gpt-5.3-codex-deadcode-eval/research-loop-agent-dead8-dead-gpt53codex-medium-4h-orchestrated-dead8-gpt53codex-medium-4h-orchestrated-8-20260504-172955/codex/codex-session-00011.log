    torch.cuda.manual_seed(CONFIG.seed)
torch.set_float32_matmul_precision(CONFIG.matmul_precision)
runtime_device = "cpu"
device = torch.device(runtime_device)
autocast_dtype = getattr(torch, CONFIG.autocast_dtype)
autocast_ctx = torch.amp.autocast(device_type=runtime_device, dtype=autocast_dtype, enabled=True)
runtime_device_batch_size = min(CONFIG.device_batch_size, 8)
runtime_total_batch_size = min(CONFIG.total_batch_size, runtime_device_batch_size * CONFIG.sequence_len)

