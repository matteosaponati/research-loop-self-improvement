def _safe_empty(*args, **kwargs):
    if kwargs.get("pin_memory", False):
        try:
            return _torch_empty_orig(*args, **kwargs)
        except torch.AcceleratorError:
            kwargs = dict(kwargs)
            kwargs["pin_memory"] = False
