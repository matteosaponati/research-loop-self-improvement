/bin/bash -lc "python - <<'PY'
import json, pathlib, subprocess
from math import inf

metrics_path = pathlib.Path('metrics.json')
if not metrics_path.exists():
    print('CRASH missing metrics.json')
    raise SystemExit(2)

m = json.loads(metrics_path.read_text())
val = float(m['val_bpb'])
mem_gb = float(m['peak_vram_mb'])/1024.0
commit = subprocess.check_output(['git','rev-parse','--short','HEAD'], text=True).strip()

results_path = pathlib.Path('memory/results.tsv')
lines = [ln for ln in results_path.read_text().splitlines() if ln.strip()]
# best prior keep value before this run
best = inf
for ln in lines[1:]:
    parts = ln.split('\\t')
    if len(parts) < 5:
        continue
    try:
        v = float(parts[1])
    except Exception:
        continue
    if parts[3] == 'keep' and v > 0:
        best = min(best, v)

status = 'keep' if val < best else 'discard'
desc = 'reduce warmdown_ratio to 0.45'
with results_path.open('a') as f:
    f.write(f\"{commit}\\t{val:.6f}\\t{mem_gb:.1f}\\t{status}\\t{desc}\\n\")

print(f\"commit={commit}\")
print(f\"val_bpb={val:.6f}\")
print(f\"mem_gb={mem_gb:.1f}\")
print(f\"prior_best_keep={best:.6f}\")
print(f\"status={status}\")
