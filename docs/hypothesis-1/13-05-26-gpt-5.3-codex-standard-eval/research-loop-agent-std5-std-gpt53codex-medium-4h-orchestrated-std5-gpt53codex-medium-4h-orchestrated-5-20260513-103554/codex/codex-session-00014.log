exec
/bin/bash -lc "uv run --extra research python - <<'PY'
import json, pathlib, subprocess
from math import inf

m = json.loads(pathlib.Path('metrics.json').read_text())
val = float(m['val_bpb'])
mem_gb = float(m['peak_vram_mb'])/1024.0
commit = subprocess.check_output(['git','rev-parse','--short','HEAD'], text=True).strip()

results = pathlib.Path('memory/results.tsv')
lines = [ln for ln in results.read_text().splitlines() if ln.strip()]
best = inf
for ln in lines[1:]:
    p = ln.split('\\t')
    if len(p) >= 4 and p[3] == 'keep':
        try:
            v = float(p[1])
            if v > 0:
                best = min(best, v)
        except:
            pass
status = 'keep' if val < best else 'discard'
with results.open('a') as f:
    f.write(f\"{commit}\\t{val:.6f}\\t{mem_gb:.1f}\\t{status}\\ttune matrix_lr to 0.02458\\n\")
print(f\"commit={commit}\")
print(f\"val_bpb={val:.6f}\")
print(f\"mem_gb={mem_gb:.1f}\")
print(f\"prior_best={best:.6f}\")
print(f\"status={status}\")
PY

