COMPILE_DYNAMIC = False

TIME_BUDGET_SECONDS = 300
WARMUP_STEPS_EXCLUDED_FROM_TIMING = 10
LOSS_FAIL_THRESHOLD = 100.0
EMA_BETA = 0.9
GC_FREEZE_AFTER_FIRST_STEP = True
GC_COLLECT_INTERVAL = 5000

