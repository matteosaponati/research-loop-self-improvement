import json, subprocess
from pathlib import Path
metrics=json.loads(Path('metrics.json').read_text())
val=float(metrics['val_bpb']); mem=float(metrics['peak_vram_mb'])/1024
commit=subprocess.check_output(['git','rev-parse','--short','HEAD'], text=True).strip()
results=Path('memory/results.tsv')
lines=[l for l in results.read_text().splitlines() if l.strip()]
best=min(float(r.split('\\t')[1]) for r in lines[1:] if len(r.split('\\t'))>=5 and r.split('\\t')[3] in {'keep','discard'})
status='keep' if val<best else 'discard'
with results.open('a',encoding='utf-8') as f:
    f.write(f\"{commit}\\t{val:.6f}\\t{mem:.1f}\\t{status}\\twarmup 1% plus warmdown 60%\\n\")
print(f\"{commit} {val:.6f} {mem:.1f} best={best:.6f} status={status}\")
