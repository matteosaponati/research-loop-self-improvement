commit = subprocess.check_output(['git','rev-parse','--short','HEAD'], text=True).strip()
val = float(metrics['val_bpb'])
peak_gb = float(metrics.get('peak_vram_mb', 0.0)) / 1024
print(commit, repr(val), f'{peak_gb:.1f}', metrics.get('total_seconds'), metrics.get('num_steps'), metrics.get('mfu_percent'))
with Path('memory/results.tsv').open('a', encoding='utf-8') as f:
    f.write(f\"{commit}\\t{val:.6f}\\t{peak_gb:.1f}\\tdiscard\\ttokenizer batch size 256\\n\")
