    82	def apply_rotary_emb(x, cos, sin):
    83	    assert x.ndim == 4
    84	    d = x.shape[3] // 2
    85	    x1, x2 = x[..., :d], x[..., d:]
    86	    y1 = x1 * cos + x2 * sin
    87	    y2 = x1 * (-sin) + x2 * cos
