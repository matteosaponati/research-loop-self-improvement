    74	    for line in text.splitlines():
    75	        line = line.split("#", 1)[0].strip()
    76	        if not line:
    77	            continue
    78	        key, raw_value = [part.strip() for part in line.split("=", 1)]
    79	        if raw_value.startswith('"') and raw_value.endswith('"'):
    80	            values[key] = raw_value[1:-1]
    81	        elif raw_value.lower() in {"true", "false"}:
    82	            values[key] = raw_value.lower() == "true"
    83	        elif "." in raw_value or "e" in raw_value.lower():
    84	            values[key] = float(raw_value)
    85	        else:
    86	            values[key] = int(raw_value)
    87	    return values
    88	
    89	
    90	def load_config(path: Path = CONFIG_PATH) -> ExperimentConfig:
    91	    text = path.read_text(encoding="utf-8")
    92	    raw: dict[str, Any] = tomllib.loads(text) if tomllib else parse_flat_toml(text)
    93	    return ExperimentConfig(**raw)
    94	
    95	
    96	CONFIG = load_config()

