 editable/train.py | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/editable/train.py b/editable/train.py
index 5252064..d380988 100644
--- a/editable/train.py
+++ b/editable/train.py
@@ -160,6 +160,7 @@ class GPT(nn.Module):
             "h": nn.ModuleList([Block(config) for _ in range(config.n_layer)]),
         })
         self.lm_head = nn.Linear(config.n_embd, config.vocab_size, bias=False)
+        self.register_buffer("logit_bias", torch.zeros(config.vocab_size), persistent=False)
         head_dim = config.n_embd // config.n_head
         # Rotary embeddings
         self.rotary_seq_len = config.sequence_len * config.rotary_seq_len_multiplier
@@ -189,6 +190,15 @@ class GPT(nn.Module):
         # Cast embeddings to bf16
         self.transformer.wte.to(dtype=torch.bfloat16)
 
+    @torch.no_grad()
+    def set_logit_bias_from_targets(self, targets, scale=0.15):
+        valid = targets[targets != self.config.ignore_index]
+        counts = torch.bincount(valid.flatten(), minlength=self.config.vocab_size).float()
+        probs = (counts + 1.0) / (counts.sum() + self.config.vocab_size)
+        bias = probs.log()
+        bias = bias - bias.mean()
+        self.logit_bias.copy_((scale * bias).clamp_(-2.0, 2.0).to(self.logit_bias.dtype))
+
     def _precompute_rotary_embeddings(self, seq_len, head_dim, base=None, device=None):
         if base is None:
             base = self.config.rotary_base
@@ -263,6 +273,7 @@ class GPT(nn.Module):
 
         softcap = self.config.softcap
         logits = self.lm_head(x)
+        logits = logits + self.logit_bias
         logits = logits.float()
         logits = softcap * torch.tanh(logits / softcap)
 
@@ -488,6 +499,8 @@ train_loader = prepare.make_dataloader(
     device=CONFIG.device,
 )
 x, y, epoch = next(train_loader)  # prefetch first batch
+bias_model = model._orig_mod if COMPILE_MODEL else model
+bias_model.set_logit_bias_from_targets(y)
 
