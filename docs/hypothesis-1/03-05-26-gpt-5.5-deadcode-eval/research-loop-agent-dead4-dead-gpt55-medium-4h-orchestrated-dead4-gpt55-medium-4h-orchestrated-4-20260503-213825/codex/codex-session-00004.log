@dataclass(frozen=True)
class ExperimentConfig:
    hf_hub_disable_progress_bars: str
    seed: int
    device: str
    matmul_precision: str
    autocast_dtype: str
    h100_bf16_peak_flops: float
    sequence_len: int
    total_batch_size: int
    device_batch_size: int
