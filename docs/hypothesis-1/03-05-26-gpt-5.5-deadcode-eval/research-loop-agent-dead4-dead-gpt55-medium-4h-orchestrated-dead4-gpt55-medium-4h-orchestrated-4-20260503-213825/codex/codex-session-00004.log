    rotary_seq_len_multiplier: int
    rotary_base: float
    softcap: float
    ignore_index: int
    init_wte_mean: float
    init_wte_std: float
    init_lm_head_mean: float
    init_lm_head_std: float
    init_matrix_scale: float
    embedding_lr: float
    unembedding_lr: float
    matrix_lr: float
    weight_decay: float
    adam_beta1: float
    adam_beta2: float
    adam_eps: float
    dmodel_lr_reference: int
    muon_initial_momentum: float
