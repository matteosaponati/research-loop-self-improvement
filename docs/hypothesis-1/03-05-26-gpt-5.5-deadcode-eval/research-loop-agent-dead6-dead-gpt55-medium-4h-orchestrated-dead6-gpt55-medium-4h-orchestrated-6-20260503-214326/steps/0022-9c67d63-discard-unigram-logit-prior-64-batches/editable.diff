+@torch.no_grad()
+def install_unigram_prior(model, loader, x, y, epoch):
+    counts = torch.ones(vocab_size, dtype=torch.float32, device=device)
+    for _ in range(UNIGRAM_PRIOR_BATCHES):
+        valid_targets = y[y != CONFIG.ignore_index]
+        counts += torch.bincount(valid_targets.flatten(), minlength=vocab_size).float()
+        x, y, epoch = next(loader)
+    log_probs = counts.log() - counts.sum().log()
+    log_probs -= log_probs.mean()
+    model.logit_bias.copy_(log_probs.to(dtype=torch.bfloat16))
+    return x, y, epoch
+
+x, y, epoch = install_unigram_prior(model, train_loader, x, y, epoch)
+
+if COMPILE_MODEL:
+    model = torch.compile(model, dynamic=COMPILE_DYNAMIC)
