   180	            torch.nn.init.uniform_(block.attn.c_k.weight, -s, s)
   181	            torch.nn.init.uniform_(block.attn.c_v.weight, -s, s)
   182	            torch.nn.init.zeros_(block.attn.c_proj.weight)
   183	            torch.nn.init.uniform_(block.mlp.c_fc.weight, -s, s)
   184	            torch.nn.init.zeros_(block.mlp.c_proj.weight)
   185	        # Rotary embeddings
   186	        head_dim = self.config.n_embd // self.config.n_head
   187	        cos, sin = self._precompute_rotary_embeddings(self.rotary_seq_len, head_dim)
   188	        self.cos, self.sin = cos, sin
   189	        # Cast embeddings to bf16
   190	        self.transformer.wte.to(dtype=torch.bfloat16)
   191	
   192	    def _precompute_rotary_embeddings(self, seq_len, head_dim, base=None, device=None):
   193	        if base is None:
   194	            base = self.config.rotary_base
   195	        if device is None:
   196	            device = self.transformer.wte.weight.device
   197	        channel_range = torch.arange(0, head_dim, 2, dtype=torch.float32, device=device)
   198	        inv_freq = 1.0 / (base ** (channel_range / head_dim))
   199	        t = torch.arange(seq_len, dtype=torch.float32, device=device)
   200	        freqs = torch.outer(t, inv_freq)
   201	        cos, sin = freqs.cos(), freqs.sin()
   202	        cos, sin = cos.bfloat16(), sin.bfloat16()
   203	        cos, sin = cos[None, :, None, :], sin[None, :, None, :]
   204	        return cos, sin
   205	
   206	    def estimate_flops(self):
   207	        """Estimated FLOPs per token (forward + backward)."""
   208	        nparams = sum(p.numel() for p in self.parameters())
   209	        nparams_exclude = self.transformer.wte.weight.numel()
   210	        h = self.config.n_head
   211	        q = self.config.n_embd // self.config.n_head
   212	        t = self.config.sequence_len
   213	        attn_flops = self.config.n_layer * 12 * h * q * t
   214	        return 6 * (nparams - nparams_exclude) + attn_flops
   215	
   216	    def num_scaling_params(self):
   217	        wte = sum(p.numel() for p in self.transformer.wte.parameters())
   218	        lm_head = sum(p.numel() for p in self.lm_head.parameters())
   219	        transformer_matrices = sum(p.numel() for p in self.transformer.h.parameters())
   220	        total = wte + lm_head + transformer_matrices
   221	        return {
   222	            'wte': wte, 'lm_head': lm_head,
   223	            'transformer_matrices': transformer_matrices, 'total': total,
   224	        }
   225	
   226	    def setup_optimizer(self, unembedding_lr, embedding_lr, matrix_lr, weight_decay,
   227	                        adam_betas, adam_eps, dmodel_lr_reference,
   228	                        muon_initial_momentum, muon_ns_steps, muon_beta2):
   229	        model_dim = self.config.n_embd
   230	        matrix_params = list(self.transformer.h.parameters())
   231	        embedding_params = list(self.transformer.wte.parameters())
   232	        lm_head_params = list(self.lm_head.parameters())
   233	        assert len(list(self.parameters())) == (len(matrix_params) + len(embedding_params) +
   234	            len(lm_head_params))
   235	        # Scale LR ∝ 1/√dmodel (tuned at 768 dim)
   236	        dmodel_lr_scale = (model_dim / dmodel_lr_reference) ** -0.5
   237	        print(f"Scaling AdamW LRs by 1/sqrt({model_dim}/{dmodel_lr_reference}) = {dmodel_lr_scale:.6f}")
   238	        param_groups = [
   239	            dict(kind='adamw', params=lm_head_params, lr=unembedding_lr * dmodel_lr_scale, betas=adam_betas, eps=adam_eps, weight_decay=0.0),
   240	            dict(kind='adamw', params=embedding_params, lr=embedding_lr * dmodel_lr_scale, betas=adam_betas, eps=adam_eps, weight_decay=0.0),
   241	        ]
   242	        for shape in sorted({p.shape for p in matrix_params}):
   243	            group_params = [p for p in matrix_params if p.shape == shape]
   244	            param_groups.append(dict(
   245	                kind='muon', params=group_params, lr=matrix_lr,
   246	                momentum=muon_initial_momentum, ns_steps=muon_ns_steps, beta2=muon_beta2, weight_decay=weight_decay,
   247	            ))
   248	        optimizer = MuonAdamW(param_groups)
   249	        for group in optimizer.param_groups:
   250	            group["initial_lr"] = group["lr"]
   251	        return optimizer
   252	
   253	    def forward(self, idx, targets=None, reduction='mean'):
   254	        B, T = idx.size()
   255	        assert T <= self.cos.size(1)
   256	        cos_sin = self.cos[:, :T], self.sin[:, :T]
   257	
   258	        x = self.transformer.wte(idx)
   259	        x = norm(x)
   260	        for block in self.transformer.h:
   261	            x = block(x, cos_sin)
   262	        x = norm(x)
   263	
   264	        softcap = self.config.softcap
   265	        logits = self.lm_head(x)
   266	        logits = logits.float()
   267	        logits = softcap * torch.tanh(logits / softcap)
   268	
   269	        if targets is not None:
   270	            loss = F.cross_entropy(logits.view(-1, logits.size(-1)), targets.view(-1),
   271	                                   ignore_index=self.config.ignore_index, reduction=reduction)
   272	            return loss
   273	        return logits
   274	
   275	# ---------------------------------------------------------------------------
   276	# Optimizer (MuonAdamW, single GPU only)
   277	# ---------------------------------------------------------------------------
   278	
   279	polar_express_coeffs = [
   280	    (8.156554524902461, -22.48329292557795, 15.878769915207462),
   281	    (4.042929935166739, -2.808917465908714, 0.5000178451051316),
   282	    (3.8916678022926607, -2.772484153217685, 0.5060648178503393),
   283	    (3.285753657755655, -2.3681294933425376, 0.46449024233003106),
   284	    (2.3465413258596377, -1.7097828382687081, 0.42323551169305323),
   285	]
   286	
   287	@torch.compile(dynamic=False, fullgraph=True)
   288	def adamw_step_fused(p, grad, exp_avg, exp_avg_sq, step_t, lr_t, beta1_t, beta2_t, eps_t, wd_t):
   289	    p.mul_(1 - lr_t * wd_t)
   290	    exp_avg.lerp_(grad, 1 - beta1_t)
   291	    exp_avg_sq.lerp_(grad.square(), 1 - beta2_t)
   292	    bias1 = 1 - beta1_t ** step_t
   293	    bias2 = 1 - beta2_t ** step_t
   294	    denom = (exp_avg_sq / bias2).sqrt() + eps_t
   295	    step_size = lr_t / bias1
   296	    p.add_(exp_avg / denom, alpha=-step_size)
   297	
   298	@torch.compile(dynamic=False, fullgraph=True)
   299	def muon_step_fused(stacked_grads, stacked_params, momentum_buffer, second_momentum_buffer,
   300	                    momentum_t, lr_t, wd_t, beta2_t, ns_steps, red_dim):
   301	    # Nesterov momentum
   302	    momentum = momentum_t.to(stacked_grads.dtype)
   303	    momentum_buffer.lerp_(stacked_grads, 1 - momentum)
   304	    g = stacked_grads.lerp_(momentum_buffer, momentum)
   305	    # Polar express orthogonalization
   306	    X = g.bfloat16()
   307	    X = X / (X.norm(dim=(-2, -1), keepdim=True) * 1.02 + 1e-6)
   308	    if g.size(-2) > g.size(-1):
   309	        for a, b, c in polar_express_coeffs[:ns_steps]:
   310	            A = X.mT @ X
   311	            B = b * A + c * (A @ A)
   312	            X = a * X + X @ B
   313	    else:
   314	        for a, b, c in polar_express_coeffs[:ns_steps]:
   315	            A = X @ X.mT
   316	            B = b * A + c * (A @ A)
   317	            X = a * X + B @ X
   318	    g = X
   319	    # NorMuon variance reduction
   320	    beta2 = beta2_t.to(g.dtype)
   321	    v_mean = g.float().square().mean(dim=red_dim, keepdim=True)
   322	    red_dim_size = g.size(red_dim)
   323	    v_norm_sq = v_mean.sum(dim=(-2, -1), keepdim=True) * red_dim_size
   324	    v_norm = v_norm_sq.sqrt()
   325	    second_momentum_buffer.lerp_(v_mean.to(dtype=second_momentum_buffer.dtype), 1 - beta2)
   326	    step_size = second_momentum_buffer.clamp_min(1e-10).rsqrt()
   327	    scaled_sq_sum = (v_mean * red_dim_size) * step_size.float().square()
   328	    v_norm_new = scaled_sq_sum.sum(dim=(-2, -1), keepdim=True).sqrt()
   329	    final_scale = step_size * (v_norm / v_norm_new.clamp_min(1e-10))
   330	    g = g * final_scale.to(g.dtype)
   331	    # Cautious weight decay + parameter update
   332	    lr = lr_t.to(g.dtype)
   333	    wd = wd_t.to(g.dtype)
   334	    mask = (g * stacked_params) >= 0
   335	    stacked_params.sub_(lr * g + lr * wd * stacked_params * mask)
   336	
   337	
   338	class MuonAdamW(torch.optim.Optimizer):
   339	    """Combined optimizer: Muon for 2D matrix params, AdamW for others."""
   340	
   341	    def __init__(self, param_groups):
   342	        super().__init__(param_groups, defaults={})
   343	        # 0-D CPU tensors to avoid torch.compile recompilation when values change
   344	        self._adamw_step_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   345	        self._adamw_lr_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   346	        self._adamw_beta1_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   347	        self._adamw_beta2_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   348	        self._adamw_eps_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   349	        self._adamw_wd_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   350	        self._muon_momentum_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   351	        self._muon_lr_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   352	        self._muon_wd_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   353	        self._muon_beta2_t = torch.tensor(0.0, dtype=torch.float32, device="cpu")
   354	
   355	    def _step_adamw(self, group):
   356	        for p in group['params']:
   357	            if p.grad is None:
   358	                continue
   359	            grad = p.grad
   360	            state = self.state[p]
   361	            if not state:
   362	                state['step'] = 0
   363	                state['exp_avg'] = torch.zeros_like(p)
   364	                state['exp_avg_sq'] = torch.zeros_like(p)
   365	            state['step'] += 1
   366	            self._adamw_step_t.fill_(state['step'])
   367	            self._adamw_lr_t.fill_(group['lr'])
   368	            self._adamw_beta1_t.fill_(group['betas'][0])
   369	            self._adamw_beta2_t.fill_(group['betas'][1])
   370	            self._adamw_eps_t.fill_(group['eps'])
   371	            self._adamw_wd_t.fill_(group['weight_decay'])
   372	            adamw_step_fused(p, grad, state['exp_avg'], state['exp_avg_sq'],
   373	                            self._adamw_step_t, self._adamw_lr_t, self._adamw_beta1_t,
   374	                            self._adamw_beta2_t, self._adamw_eps_t, self._adamw_wd_t)
   375	
   376	    def _step_muon(self, group):
   377	        params = group['params']
   378	        if not params:
   379	            return
   380	        p = params[0]
   381	        state = self.state[p]
   382	        num_params = len(params)
   383	        shape, device, dtype = p.shape, p.device, p.dtype
   384	        if "momentum_buffer" not in state:
   385	            state["momentum_buffer"] = torch.zeros(num_params, *shape, dtype=dtype, device=device)
   386	        if "second_momentum_buffer" not in state:
   387	            state_shape = (num_params, shape[-2], 1) if shape[-2] >= shape[-1] else (num_params, 1, shape[-1])
   388	            state["second_momentum_buffer"] = torch.zeros(state_shape, dtype=dtype, device=device)
   389	        red_dim = -1 if shape[-2] >= shape[-1] else -2
   390	        stacked_grads = torch.stack([p.grad for p in params])
   391	        stacked_params = torch.stack(params)
   392	        self._muon_momentum_t.fill_(group["momentum"])
   393	        self._muon_beta2_t.fill_(group["beta2"] if group["beta2"] is not None else 0.0)
   394	        self._muon_lr_t.fill_(group["lr"] * max(1.0, shape[-2] / shape[-1])**0.5)
   395	        self._muon_wd_t.fill_(group["weight_decay"])
   396	        muon_step_fused(stacked_grads, stacked_params,
   397	                        state["momentum_buffer"], state["second_momentum_buffer"],
   398	                        self._muon_momentum_t, self._muon_lr_t, self._muon_wd_t,
   399	                        self._muon_beta2_t, group["ns_steps"], red_dim)
   400	        torch._foreach_copy_(params, list(stacked_params.unbind(0)))
   401	
   402	    @torch.no_grad()
   403	    def step(self):
   404	        for group in self.param_groups:
   405	            if group['kind'] == 'adamw':
   406	                self._step_adamw(group)
   407	            elif group['kind'] == 'muon':
   408	                self._step_muon(group)
   409	
   410	# ---------------------------------------------------------------------------
   411	# Setup: tokenizer, model, optimizer, dataloader
   412	# ---------------------------------------------------------------------------
   413	
   414	t_start = time.time()
   415	torch.manual_seed(CONFIG.seed)
   416	torch.cuda.manual_seed(CONFIG.seed)
   417	torch.set_float32_matmul_precision(CONFIG.matmul_precision)
   418	device = torch.device(CONFIG.device)
   419	autocast_dtype = getattr(torch, CONFIG.autocast_dtype)
   420	autocast_ctx = torch.amp.autocast(device_type=CONFIG.device, dtype=autocast_dtype)
   421	
   422	tokenizer = prepare.Tokenizer.from_directory(os.path.expanduser(str(prepare.TOKENIZER_DIR)))
   423	vocab_size = tokenizer.get_vocab_size()
   424	print(f"Vocab size: {vocab_size:,}")
   425	
   426	def build_model_config():
   427	    base_dim = CONFIG.depth * CONFIG.aspect_ratio
   428	    model_dim = ((base_dim + CONFIG.head_dim - 1) // CONFIG.head_dim) * CONFIG.head_dim
   429	    num_heads = model_dim // CONFIG.head_dim
   430	    return GPTConfig(
   431	        sequence_len=CONFIG.sequence_len, vocab_size=vocab_size,
   432	        n_layer=CONFIG.depth, n_head=num_heads, n_embd=model_dim,
   433	        mlp_hidden_multiplier=CONFIG.mlp_hidden_multiplier,
   434	        rotary_seq_len_multiplier=CONFIG.rotary_seq_len_multiplier,
   435	        rotary_base=CONFIG.rotary_base,
   436	        softcap=CONFIG.softcap,
   437	        ignore_index=CONFIG.ignore_index,
   438	        init_wte_mean=CONFIG.init_wte_mean,
   439	        init_wte_std=CONFIG.init_wte_std,
   440	        init_lm_head_mean=CONFIG.init_lm_head_mean,
   441	        init_lm_head_std=CONFIG.init_lm_head_std,
   442	        init_matrix_scale=CONFIG.init_matrix_scale,
   443	    )
   444	
   445	config = build_model_config()
   446	print(f"Model config: {asdict(config)}")
   447	
   448	with torch.device("meta"):
   449	    model = GPT(config)
   450	model.to_empty(device=device)
   451	model.init_weights()
   452	
   453	param_counts = model.num_scaling_params()
   454	print("Parameter counts:")
   455	for key, value in param_counts.items():
   456	    print(f"  {key:24s}: {value:,}")
   457	num_params = param_counts['total']
   458	num_flops_per_token = model.estimate_flops()
   459	print(f"Estimated FLOPs per token: {num_flops_per_token:e}")
   460	
   461	tokens_per_fwdbwd = CONFIG.device_batch_size * CONFIG.sequence_len
   462	assert CONFIG.total_batch_size % tokens_per_fwdbwd == 0
   463	grad_accum_steps = CONFIG.total_batch_size // tokens_per_fwdbwd
   464	
   465	optimizer = model.setup_optimizer(
   466	    unembedding_lr=CONFIG.unembedding_lr,
   467	    embedding_lr=CONFIG.embedding_lr,
   468	    adam_betas=CONFIG.adam_betas,
   469	    matrix_lr=CONFIG.matrix_lr,
   470	    weight_decay=CONFIG.weight_decay,
   471	    adam_eps=CONFIG.adam_eps,
   472	    dmodel_lr_reference=CONFIG.dmodel_lr_reference,
   473	    muon_initial_momentum=CONFIG.muon_initial_momentum,
   474	    muon_ns_steps=CONFIG.muon_ns_steps,
   475	    muon_beta2=CONFIG.muon_beta2,
   476	)
   477	
   478	if COMPILE_MODEL:
   479	    model = torch.compile(model, dynamic=COMPILE_DYNAMIC)
   480	
   481	train_loader = prepare.make_dataloader(
   482	    tokenizer,
   483	    CONFIG.device_batch_size,
   484	    CONFIG.sequence_len,
   485	    "train",
   486	    buffer_size=CONFIG.dataloader_buffer_size,
   487	    tokenizer_batch_size=CONFIG.tokenizer_batch_size,
   488	    device=CONFIG.device,
   489	)
   490	x, y, epoch = next(train_loader)  # prefetch first batch
   491	
   492	print(f"Time budget: {TIME_BUDGET_SECONDS}s")
   493	print(f"Gradient accumulation steps: {grad_accum_steps}")
   494	
   495	# Schedules (all based on progress = training_time / TIME_BUDGET_SECONDS)
   496	
   497	def get_lr_multiplier(progress):
   498	    if progress < CONFIG.warmup_ratio:
   499	        return progress / CONFIG.warmup_ratio if CONFIG.warmup_ratio > 0 else 1.0
   500	    elif progress < 1.0 - CONFIG.warmdown_ratio:
   501	        return 1.0
   502	    else:
   503	        cooldown = (1.0 - progress) / CONFIG.warmdown_ratio
   504	        return cooldown * 1.0 + (1 - cooldown) * CONFIG.final_lr_frac
   505	
   506	def get_muon_momentum(step):
   507	    frac = min(step / CONFIG.muon_momentum_warmup_steps, 1)
   508	    return (1 - frac) * CONFIG.muon_momentum_start + frac * CONFIG.muon_momentum_end
   509	
   510	def get_weight_decay(progress):
   511	    return CONFIG.weight_decay * (1 - progress) if CONFIG.weight_decay_decay else CONFIG.weight_decay
   512	
   513	# ---------------------------------------------------------------------------
   514	# Training loop
   515	# ---------------------------------------------------------------------------
   516	
   517	t_start_training = time.time()
   518	smooth_train_loss = 0
   519	total_training_time = 0
   520	step = 0
   521	
   522	while True:
   523	    torch.cuda.synchronize()
   524	    t0 = time.time()
   525	    for micro_step in range(grad_accum_steps):
   526	        with autocast_ctx:
   527	            loss = model(x, y)
   528	        train_loss = loss.detach()
   529	        loss = loss / grad_accum_steps
   530	        loss.backward()
   531	        x, y, epoch = next(train_loader)
   532	
   533	    # Progress and schedules
   534	    progress = min(total_training_time / TIME_BUDGET_SECONDS, 1.0)
   535	    lrm = get_lr_multiplier(progress)
   536	    muon_momentum = get_muon_momentum(step)
   537	    muon_weight_decay = get_weight_decay(progress)
   538	    for group in optimizer.param_groups:
   539	        group["lr"] = group["initial_lr"] * lrm
   540	        if group['kind'] == 'muon':
   541	            group["momentum"] = muon_momentum
   542	            group["weight_decay"] = muon_weight_decay
   543	    optimizer.step()
   544	    model.zero_grad(set_to_none=True)
   545	
   546	    train_loss_f = train_loss.item()
   547	
   548	    # Fast fail: abort if loss is exploding or NaN
   549	    if math.isnan(train_loss_f) or train_loss_f > LOSS_FAIL_THRESHOLD:
   550	        print("FAIL")
   551	        exit(1)
   552	
   553	    torch.cuda.synchronize()
   554	    t1 = time.time()
   555	    dt = t1 - t0
   556	
   557	    if step > WARMUP_STEPS_EXCLUDED_FROM_TIMING:
   558	        total_training_time += dt
   559	
   560	    # Logging
   561	    ema_beta = EMA_BETA
   562	    smooth_train_loss = ema_beta * smooth_train_loss + (1 - ema_beta) * train_loss_f
   563	    debiased_smooth_loss = smooth_train_loss / (1 - ema_beta**(step + 1))
   564	    pct_done = 100 * progress
   565	    tok_per_sec = int(CONFIG.total_batch_size / dt)
   566	    mfu = 100 * num_flops_per_token * CONFIG.total_batch_size / dt / CONFIG.h100_bf16_peak_flops
   567	    remaining = max(0, TIME_BUDGET_SECONDS - total_training_time)
   568	
   569	    print(f"\rstep {step:05d} ({pct_done:.1f}%) | loss: {debiased_smooth_loss:.6f} | lrm: {lrm:.2f} | dt: {dt*1000:.0f}ms | tok/sec: {tok_per_sec:,} | mfu: {mfu:.1f}% | epoch: {epoch} | remaining: {remaining:.0f}s    ", end="", flush=True)
   570	
   571	    # GC management (Python's GC causes ~500ms stalls)
   572	    if step == 0 and GC_FREEZE_AFTER_FIRST_STEP:
   573	        gc.collect()
   574	        gc.freeze()
   575	        gc.disable()
   576	    elif GC_COLLECT_INTERVAL > 0 and (step + 1) % GC_COLLECT_INTERVAL == 0:
   577	        gc.collect()
   578	
   579	    step += 1
   580	
   581	    # Time's up — but only stop after warmup steps so we don't count compilation
   582	    if step > WARMUP_STEPS_EXCLUDED_FROM_TIMING and total_training_time >= TIME_BUDGET_SECONDS:
   583	        break
   584	
   585	print()  # newline after \r training log
   586	
   587	total_tokens = step * CONFIG.total_batch_size
   588	
   589	# Final eval
   590	model.eval()
   591	with autocast_ctx:
   592	    metric_value = evaluate_model(
   593	        model,
   594	        tokenizer,
   595	        CONFIG.device_batch_size,
   596	        sequence_len=CONFIG.sequence_len,
   597	        buffer_size=CONFIG.dataloader_buffer_size,
   598	        tokenizer_batch_size=CONFIG.tokenizer_batch_size,
   599	        device=CONFIG.device,
   600	    )
   601	
   602	# Final summary
   603	t_end = time.time()
   604	startup_time = t_start_training - t_start
   605	timed_steps = step - WARMUP_STEPS_EXCLUDED_FROM_TIMING
   606	steady_state_mfu = 100 * num_flops_per_token * CONFIG.total_batch_size * timed_steps / total_training_time / CONFIG.h100_bf16_peak_flops if total_training_time > 0 else 0
   607	peak_vram_mb = torch.cuda.max_memory_allocated() / 1024 / 1024
