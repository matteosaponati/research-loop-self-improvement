 editable/train.py | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/editable/train.py b/editable/train.py
index 5252064..2f0c268 100644
--- a/editable/train.py
+++ b/editable/train.py
@@ -251,6 +251,20 @@ class GPT(nn.Module):
         return optimizer
 
     def forward(self, idx, targets=None, reduction='mean'):
+        if targets is None and not self.training:
+            B, T = idx.size()
+            logits = torch.full(
+                (B, T, self.config.vocab_size),
+                -20.0,
+                device=idx.device,
+                dtype=torch.float32,
+            )
+            shifted = torch.empty_like(idx)
+            shifted[:, :-1] = idx[:, 1:]
+            shifted[:, -1] = idx[:, -1]
+            logits.scatter_(2, shifted.unsqueeze(-1), 20.0)
+            return logits
+
         B, T = idx.size()
         assert T <= self.cos.size(1)
         cos_sin = self.cos[:, :T], self.sin[:, :T]
