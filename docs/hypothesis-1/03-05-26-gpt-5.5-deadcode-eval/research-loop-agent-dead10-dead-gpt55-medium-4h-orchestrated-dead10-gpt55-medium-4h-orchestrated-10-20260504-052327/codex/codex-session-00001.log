   100	class CausalSelfAttention(nn.Module):
   101	    def __init__(self, config):
   102	        super().__init__()
   103	        self.n_head = config.n_head
   104	        self.n_embd = config.n_embd
   105	        self.head_dim = self.n_embd // self.n_head
   106	        assert self.n_embd % self.n_head == 0
   107	        self.c_q = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   108	        self.c_k = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   109	        self.c_v = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   110	        self.c_proj = nn.Linear(self.n_embd, self.n_embd, bias=False)
   111	
   112	    def forward(self, x, cos_sin):
   113	        B, T, C = x.size()
   114	        q = self.c_q(x).view(B, T, self.n_head, self.head_dim)
   115	        k = self.c_k(x).view(B, T, self.n_head, self.head_dim)
   116	        v = self.c_v(x).view(B, T, self.n_head, self.head_dim)
   117	
   118	        cos, sin = cos_sin
   119	        q, k = apply_rotary_emb(q, cos, sin), apply_rotary_emb(k, cos, sin)
   120	        q, k = norm(q), norm(k)
   121	
   122	        y = standard_attention(q, k, v)
   123	        y = y.contiguous().view(B, T, -1)
   124	        y = self.c_proj(y)
   125	        return y
