commit=subprocess.check_output(['git','rev-parse','--short=7','HEAD'], text=True).strip()
mem=m['peak_vram_mb']/1024
best=min(float(line.split('\\t')[1]) for line in Path('memory/results.tsv').read_text().splitlines()[1:] if line.split('\\t')[3]=='keep')
status='keep' if m['val_bpb'] < best else 'discard'
Path('memory/results.tsv').open('a', encoding='utf-8').write(f\"{commit}\\t{m['val_bpb']:.6f}\\t{mem:.1f}\\t{status}\\tdevice batch 192 global batch 393216\\n\")
print(json.dumps(m, sort_keys=True))
print('best_before', best, 'status', status)
