def get_lr_multiplier(progress):
    if progress < CONFIG.warmup_ratio:
        return progress / CONFIG.warmup_ratio if CONFIG.warmup_ratio > 0 else 1.0
    elif progress < 1.0 - CONFIG.warmdown_ratio:
        return 1.0
    else:
