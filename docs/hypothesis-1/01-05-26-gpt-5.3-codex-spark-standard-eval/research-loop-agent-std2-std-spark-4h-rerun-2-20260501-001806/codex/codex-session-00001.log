val_bpb=$(grep '"'"'^val_bpb:'"' run.log | tail -n1 | awk '{print "'$2}'"')
if [ -z \""'$val_bpb" ]; then
  status=crash
  val_bpb=0.000000
  memory_gb=0.0
else
  peak_mb=$(grep '"'"'^peak_vram_mb:'"' run.log | tail -n1 | awk '{print "'$2}'"')
  memory_gb="'$(awk -v x="$peak_mb" '"'BEGIN{printf \"%.1f\", x/1024}')
  status=discard
fi
echo -e \""'$commit'"\\t"'$val_bpb'"\\t"'$memory_gb'"\\t"'$status'"\\tincrease softcap to 20\" >> memory/results.tsv
cat memory/results.tsv

