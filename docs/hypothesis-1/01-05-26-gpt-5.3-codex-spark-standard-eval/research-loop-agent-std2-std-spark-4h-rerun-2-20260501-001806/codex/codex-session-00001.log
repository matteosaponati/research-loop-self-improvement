  peak_mb=$(grep '"'"'^peak_vram_mb:'"' run.log | tail -n1 | awk '{print "'$2}'"')
  memory_gb="'$(awk -v x="$peak_mb" '"'BEGIN{printf \"%.1f\", x/1024}')
