    67	    init_wte_mean: float
    68	    init_wte_std: float
    69	    init_lm_head_mean: float
    70	    init_lm_head_std: float
    71	    init_matrix_scale: float
    72	
    73	
    74	def norm(x):
    75	    return F.rms_norm(x, (x.size(-1),))
    76	
    77	
    78	def apply_rotary_emb(x, cos, sin):
    79	    assert x.ndim == 4
    80	    d = x.shape[3] // 2
    81	    x1, x2 = x[..., :d], x[..., d:]
    82	    y1 = x1 * cos + x2 * sin
    83	    y2 = x1 * (-sin) + x2 * cos
    84	    return torch.cat([y1, y2], 3)
    85	
    86	
    87	def standard_attention(q, k, v):
    88	    """Full causal self-attention through PyTorch SDPA."""
    89	    q = q.transpose(1, 2)
    90	    k = k.transpose(1, 2)
    91	    v = v.transpose(1, 2)
    92	    y = F.scaled_dot_product_attention(q, k, v, is_causal=True)
    93	    return y.transpose(1, 2)
    94	
    95	
    96	class CausalSelfAttention(nn.Module):
    97	    def __init__(self, config):
    98	        super().__init__()
    99	        self.n_head = config.n_head
   100	        self.n_embd = config.n_embd
   101	        self.head_dim = self.n_embd // self.n_head
   102	        assert self.n_embd % self.n_head == 0
   103	        self.c_q = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   104	        self.c_k = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   105	        self.c_v = nn.Linear(self.n_embd, self.n_head * self.head_dim, bias=False)
   106	        self.c_proj = nn.Linear(self.n_embd, self.n_embd, bias=False)
   107	
   108	    def forward(self, x, cos_sin):
   109	        B, T, C = x.size()
   110	        q = self.c_q(x).view(B, T, self.n_head, self.head_dim)
   111	        k = self.c_k(x).view(B, T, self.n_head, self.head_dim)
   112	        v = self.c_v(x).view(B, T, self.n_head, self.head_dim)
   113	
   114	        cos, sin = cos_sin
   115	        q, k = apply_rotary_emb(q, cos, sin), apply_rotary_emb(k, cos, sin)
   116	        q, k = norm(q), norm(k)
   117	
   118	        y = standard_attention(q, k, v)
   119	        y = y.contiguous().view(B, T, -1)
   120	        y = self.c_proj(y)

