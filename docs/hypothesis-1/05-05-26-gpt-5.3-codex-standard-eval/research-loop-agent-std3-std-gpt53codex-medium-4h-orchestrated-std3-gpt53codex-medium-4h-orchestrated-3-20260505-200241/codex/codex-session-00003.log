    if step == 0 and GC_FREEZE_AFTER_FIRST_STEP:
        gc.collect()
        gc.freeze()
        gc.disable()
    elif GC_COLLECT_INTERVAL > 0 and (step + 1) % GC_COLLECT_INTERVAL == 0:
        gc.collect()

    step += 1

