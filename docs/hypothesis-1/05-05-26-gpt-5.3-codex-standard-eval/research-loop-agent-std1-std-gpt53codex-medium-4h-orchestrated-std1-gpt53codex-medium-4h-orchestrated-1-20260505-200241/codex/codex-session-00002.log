import torch.nn.functional as F

from immutable import prepare

prepare.DATA_DIR = os.path.expanduser(str(prepare.DATA_DIR))
prepare.TOKENIZER_DIR = os.path.expanduser(str(prepare.TOKENIZER_DIR))
